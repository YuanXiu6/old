                </div>
            </div>
            <div class="memo-entry-btn" onclick="switchToMemo()">
                <span style="font-size:24px;">📝</span> 查看备忘录
            </div>
        </div>

        <div class="section-title">今日推荐</div>
        <!-- 卡片 1 -->
        <div class="feature-card">
            <img src="https://artifacts-cdn.chatglm.site/https://picsum.photos/seed/park_health/800/400" class="card-img" alt="公园">
            <div class="card-body">
                <div class="card-title">滨河公园晨练</div>
                <div class="card-desc">监测到您久坐，建议去公园慢走20分钟，吸吸氧。</div>
                <div class="card-actions">
                    <button class="action-btn btn-nav" onclick="handleNavigate(&#39;滨河公园&#39;)">🧭 去这里</button>
                    <button class="action-btn btn-memo" onclick="handleAddMemo(&#39;去滨河公园晨练&#39;)">📝 记下来</button>
                    <button class="action-btn btn-detail" onclick="handleDetail(&#39;太极拳教学&#39;)">🔍 详情</button>
                </div>
            </div>
        </div>
        <!-- 卡片 2 -->
        <div class="feature-card">
            <img src="https://artifacts-cdn.chatglm.site/https://picsum.photos/seed/relax/800/400" class="card-img" alt="茶艺">
            <div class="card-body">
                <div class="card-title">社区茶艺会</div>
                <div class="card-desc">下午2点，社区活动中心有免费茶艺体验。</div>
                <div class="card-actions">
                    <button class="action-btn btn-nav" onclick="handleNavigate(&#39;社区活动中心&#39;)">🧭 去这里</button>
                    <button class="action-btn btn-memo" onclick="handleAddMemo(&#39;参加茶艺会&#39;)">📝 记下来</button>
                    <button class="action-btn btn-detail" onclick="handleDetail(&#39;茶艺时间表&#39;)">🔍 详情</button>
                </div>
            </div>
        </div>
    </div>

    <!-- 主页面：备忘录页 -->
    <div id="page-memos" class="page-container hidden">
        <h2 class="section-title">我的备忘录</h2>
        <ul id="memo-list-container" class="memo-list"></ul>
        <div style="text-align:center; color:#BDC3C7; margin-top:60px; display:none;" id="empty-memo-tip">
            <div style="font-size:40px; margin-bottom:10px;">📝</div>
            <div>暂无备忘录，点击右下角添加</div>
        </div>
        <button class="add-memo-btn" onclick="openAIChat(&#39;memo&#39;)">+</button>
    </div>

    <!-- AI 对话框 -->
    <div id="ai-chat-box">
        <div class="chat-header">
            <div class="chat-title">🤖 智能语音助手</div>
            <button class="chat-close-btn" onclick="closeAIChat()">✕</button>
        </div>
        <div class="chat-body" id="chat-history">
            <div class="chat-msg msg-ai">李爷爷，我在听。您可以按住麦克风说话，或者直接打字。</div>
        </div>
        <div class="chat-input-area">
            <input type="text" id="chat-text-input" class="chat-input" placeholder="说点什么..." onkeypress="if(event.key===&#39;Enter&#39;) sendChat()">
            <button class="chat-btn-circle chat-voice-btn" onmousedown="startVoice()" onmouseup="stopVoice()" ontouchstart="startVoice()" ontouchend="stopVoice()">🎤</button>
            <button class="chat-btn-circle chat-send-btn" onclick="sendChat()">➤</button>
        </div>
    </div>

    <!-- 导航弹窗 (复用样式) -->
    <div id="nav-modal" class="care-toast" style="background: white; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 25px; text-align: center; color: rgb(51, 51, 51); top: 50%; transform: translate(-50%, -50%); display: none;">
        <h2 style="color:#2980B9; margin:0 0 15px 0;">正在前往 <span id="nav-dest">滨河公园</span></h2>
        <p style="font-size:18px; color:#666; margin-bottom:25px;">1. 出门向南直走 50米<br>2. 红绿灯左转<br>3. 步行10分钟到达</p>
        <button class="action-btn btn-nav" style="width:100%; margin:0;" onclick="openSystemMap()">打开手机地图</button>
        <button class="action-btn btn-memo" style="margin-top:10px; width:100%;" onclick="document.getElementById(&#39;nav-modal&#39;).style.display=&#39;none&#39;">关闭</button>
    </div>

    <!-- 底部导航 -->
    <nav>
        <div class="nav-item active" onclick="switchTab(&#39;home&#39;, this)">
            <div class="nav-icon">🏠</div>
            <div class="nav-text">首页</div>
        </div>
        <div class="nav-item" onclick="switchTab(&#39;memos&#39;, this)">
            <div class="nav-icon">📝</div>
            <div class="nav-text">备忘</div>
        </div>
        <div class="nav-item" onclick="showToast(&#39;更多功能开发中&#39;)">
            <div class="nav-icon">🛠️</div>
            <div class="nav-text">工具</div>
        </div>
    </nav>

    <script>
        // ================= 数据与状态 =================
        let memos = JSON.parse(localStorage.getItem('elderly_memos_v2')) || [];
        const careMessages = [
            { icon: "💧", title: "该喝水了", desc: "两小时没喝水了，身体需要水分。" },
            { icon: "🧥", title: "注意保暖", desc: "室外温度降低了，出门记得加件外套。" },
            { icon: "🦶", title: "起来走走", desc: "坐太久了，起来活动活动筋骨吧。" },
            { icon: "💊", title: "吃药提醒", desc: "距离上次吃药已过4小时。" }
        ];

        // ================= 页面交互逻辑 =================
        function switchTab(tabName, el) {
            document.querySelectorAll('.page-container').forEach(p => p.classList.add('hidden'));
            document.getElementById('page-' + tabName).classList.remove('hidden');
            
            document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
            el.classList.add('active');
            
            if(tabName === 'memos') renderMemos();
        }

        function switchToMemo() {
            const navItems = document.querySelectorAll('.nav-item');
            switchTab('memos', navItems[1]);
        }

        // ================= AI 对话框逻辑 =================
        function openAIChat(mode = 'chat') {
            const box = document.getElementById('ai-chat-box');
            box.classList.add('open');
            const input = document.getElementById('chat-text-input');
            setTimeout(() => input.focus(), 400);
            if(mode === 'memo') input.value = "记一下，";
        }

        function closeAIChat() {
            document.getElementById('ai-chat-box').classList.remove('open');
        }

        function appendChat(text, sender) {
            const history = document.getElementById('chat-history');
            const div = document.createElement('div');
            div.className = `chat-msg msg-${sender}`;
            div.innerText = text;
            history.appendChild(div);
            history.scrollTop = history.scrollHeight;
        }

        function sendChat() {
            const input = document.getElementById('chat-text-input');
            const text = input.value.trim();
            if(!text) return;
            
            appendChat(text, 'user');
            input.value = '';

            setTimeout(() => {
                let reply = "好的，我记住了。";
                if (text.includes("记") || text.includes("备忘")) {
                    const content = text.replace("记一下，", "").replace("帮我记", "").replace("记下来", "");
                    if(content) {
                        handleAddMemo(content, true);
                        reply = "✅ 已经帮您记到备忘录里了。";
                    }
                } else if (text.includes("饿")) {
                    reply = "是不是到饭点了？想吃点软糯的食物吗？";
                } else if (text.includes("累")) {
                    reply = "累了就休息一会儿，或者我放首戏给您听？";
                }
                appendChat(reply, 'ai');
            }, 600);
        }

        // 语音
        let recognition;
        if ('webkitSpeechRecognition' in window) {
            recognition = new webkitSpeechRecognition();
            recognition.continuous = false; recognition.lang = 'zh-CN';
            recognition.onresult = e => {
                document.getElementById('chat-text-input').value = e.results[0][0].transcript;
                sendChat();
            };
        }
        function startVoice() { if(recognition) recognition.start(); }
        function stopVoice() { if(recognition) recognition.stop(); }

        // ================= 备忘录逻辑 =================
        function handleAddMemo(content, fromChat = false) {
            if(!content) return;
            const newMemo = { id: Date.now(), text: content, date: new Date().toLocaleString() };
            memos.unshift(newMemo);
            localStorage.setItem('elderly_memos_v2', JSON.stringify(memos));
            if(!fromChat) showToast("✅ 已保存备忘");
            renderMemos();
        }

        function renderMemos() {
            const list = document.getElementById('memo-list-container');
            const tip = document.getElementById('empty-memo-tip');
            list.innerHTML = '';
            if(memos.length === 0) tip.style.display = 'block';
            else {
                tip.style.display = 'none';
                memos.forEach(memo => {
                    const li = document.createElement('li');
                    li.className = 'memo-item';
                    li.innerHTML = `
                        <div class="memo-time">${memo.date}</div>
                        <div class="memo-content">${memo.text}</div>
                        <button class="memo-del" onclick="deleteMemo(${memo.id})">🗑️</button>
                    `;
                    list.appendChild(li);
                });
            }
        }

        function deleteMemo(id) {
            if(confirm("确定删除这条备忘吗？")) {
                memos = memos.filter(m => m.id !== id);
                localStorage.setItem('elderly_memos_v2', JSON.stringify(memos));
                renderMemos();
                showToast("已删除");
            }
        }

        // ================= 其他功能 =================
        function showToast(msg) {
            const toast = document.getElementById('toast');
            toast.innerText = msg;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 2000);
        }

        function updateClock() {
            const now = new Date();
            document.getElementById('clock').innerText = now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0');
        }
        setInterval(updateClock, 1000); updateClock();

        // 健康模拟
        let steps = 1240; let baseHr = 72;
        setInterval(() => {
            baseHr = 70 + Math.floor(Math.random() * 10);
            document.getElementById('val-hr').innerText = baseHr;
            steps += Math.floor(Math.random() * 3);
            document.getElementById('val-steps').innerText = steps.toLocaleString();
        }, 3000);

        // 关心提醒
        function initCareReminders() {
            setInterval(() => {
                const msg = careMessages[Math.floor(Math.random() * careMessages.length)];
                const toast = document.getElementById('care-toast');
                document.getElementById('care-title').innerText = msg.title;
                document.getElementById('care-desc').innerText = msg.desc;
                toast.querySelector('.care-icon').innerText = msg.icon;
                toast.classList.add('show');
                setTimeout(() => toast.classList.remove('show'), 8000);
            }, 25000); // 25秒一次
        }
        setTimeout(initCareReminders, 5000);

        // 导航
        function handleNavigate(dest) {
            document.getElementById('nav-dest').innerText = dest;
            document.getElementById('nav-modal').style.display = 'block';
        }
        function openSystemMap() {
            window.open('https://uri.amap.com/marker?position=&name='+document.getElementById('nav-dest').innerText, '_blank');
            document.getElementById('nav-modal').style.display = 'none';
        }
        function handleDetail(t) { showToast("查看详情: " + t); }
        function handleSOS() { if(confirm("确定发送求助？")) showToast("🚑 求助已发送！"); }

    </script>


			
		
</body></html>
