    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>智伴夕阳 - 智能守护导航</title>
    <style>
        /* 基础设置 */
        :root {
            --bg-color: #FFF8E7;
            --main-color: #E67E22;
            --nav-blue: #2980B9;
            --text-color: #2C3E50;
            --card-bg: #FFFFFF;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: "Microsoft YaHei", sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            height: 100vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            user-select: none;
        }

        .hidden { display: none !important; }
        .full-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            z-index: 100; background: #fff;
        }
        .btn {
            background: var(--main-color); color: white; border: none;
            padding: 12px; font-size: 18px; border-radius: 10px; width: 100%; cursor: pointer; margin-bottom: 10px;
        }
        .card {
            background: var(--card-bg); border-radius: 15px;
            padding: 15px; margin-bottom: 15px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); position: relative;
        }

        /* 导航栏 */
        nav {
            position: fixed; bottom: 0; left: 0; width: 100%; height: 70px;
            background: #fff; border-top: 1px solid #eee;
            display: flex; justify-content: space-around; align-items: center;
            z-index: 90;
        }
        .nav-item { font-size: 14px; color: #95A5A6; text-align: center; cursor: pointer; flex: 1; }
        .nav-item.active { color: var(--main-color); font-weight: bold; }
        .nav-icon { font-size: 24px; display: block; margin-bottom: 2px; }

        /* 页面通用 */
        [id^="page-"] { padding: 20px; padding-bottom: 80px; overflow-y: auto; height: 100%; box-sizing: border-box; }

        /* --- 导航按钮样式 --- */
        .nav-go-btn {
            position: absolute; bottom: 15px; right: 15px;
            background: var(--nav-blue); color: white;
            padding: 8px 15px; border-radius: 20px; border: none;
            font-size: 16px; cursor: pointer; display: flex; align-items: center; gap: 5px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.2);
        }

        /* ================= 智能导航全屏覆盖层 ================= */
        #nav-overlay {
            background: #ECF0F1;
            display: flex; flex-direction: column;
            z-index: 200;
        }
        
        .nav-header {
            background: var(--nav-blue); color: white;
            padding: 20px; text-align: center; font-size: 24px; font-weight: bold;
            position: relative;
        }
        .nav-close { position: absolute; left: 15px; top: 20px; background: none; border: none; color: white; font-size: 20px; cursor: pointer; }

        .nav-map-preview {
            height: 250px; background: #ddd; display: flex; align-items: center; justify-content: center;
            color: #7F8C8D; font-size: 20px; position: relative;
        }
        .nav-map-preview img { width: 100%; height: 100%; object-fit: cover; opacity: 0.6; }

        .nav-steps {
            flex: 1; padding: 20px; overflow-y: auto;
        }

        .step-item {
            background: white; padding: 20px; border-radius: 10px; margin-bottom: 15px;
            display: flex; align-items: center; gap: 15px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }
        .step-icon {
            width: 50px; height: 50px; border-radius: 50%;
            background: #EBF5FB; color: var(--nav-blue);
            display: flex; align-items: center; justify-content: center;
            font-size: 24px; flex-shrink: 0;
        }
        .step-text { font-size: 20px; line-height: 1.4; }
        .step-action {
            background: none; border: none; color: var(--main-color);
            font-size: 16px; cursor: pointer; display: block; margin-top: 5px;
        }

        .nav-actions {
            padding: 20px; background: white; border-top: 1px solid #ddd;
            display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
        }
        .nav-btn-home { grid-column: span 2; background: #27AE60; }

    </style>



