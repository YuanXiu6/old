    <script>
        // 模拟导航数据
        const routes = {
            'health': [
                { icon: '⬆️', text: '出门向南直走 50 米', dist: '50米' },
                { icon: '↩️', text: '在红绿灯路口左转', dist: '100米' },
                { icon: '🌳', text: '进入滨河公园北门', dist: '到达' }
            ],
            'scenic': [
                { icon: '⬆️', text: '出门向东直行', dist: '200米' },
                { icon: '🚌', text: '乘坐 102 路公交车 (3站)', dist: '15分钟' },
                { icon: '🚶', text: '下车后直走即到公园南门', dist: '到达' }
            ],
            'pharmacy': [
                { icon: '⬆️', text: '出门向西直走 100 米', dist: '100米' },
                { icon: '↩️', text: '右转进入商业街', dist: '50米' },
                { icon: '💊', text: '仁心大药房在路右侧', dist: '到达' }
            ],
            'home': [
                { icon: '🏠', text: '正在为您规划回家的路...', dist: '计算中' },
                { icon: '⬆️', text: '原路返回，向北走 200 米', dist: '200米' },
                { icon: '🚪', text: '到达幸福小区 3 号楼', dist: '到家' }
            ],
            'default': [
                { icon: '⬆️', text: '当前路向南直走', dist: '500米' },
                { icon: '↩️', text: '路口左转', dist: '1.2公里' },
                { icon: '📍', text: '到达目的地附近', dist: '到达' }
            ]
        };

        let voiceEnabled = false;
        let synthesis = window.speechSynthesis;

        function switchTab(tabId, el) {
            document.querySelectorAll('[id^="page-"]').forEach(p => p.classList.add('hidden'));
            document.getElementById('page-' + tabId).classList.remove('hidden');
            document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
            el.classList.add('active');
        }

        function startNavigation(destName, type) {
            document.getElementById('nav-dest-name').innerText = destName;
            document.getElementById('nav-overlay').classList.remove('hidden');
            
            // 渲染路线步骤
            const steps = routes[type] || routes['default'];
            const container = document.getElementById('nav-steps-container');
            container.innerHTML = '';

            steps.forEach((step, index) => {
                const div = document.createElement('div');
                div.className = 'step-item';
                div.innerHTML = `
                    <div class="step-icon">${step.icon}</div>
                    <div style="flex:1;">
                        <div class="step-text">${step.text}</div>
                        <div style="color:#999; font-size:14px;">距离 ${step.dist}</div>
                        <button class="step-action" onclick="speakText('${step.text}')">🔊 听一遍</button>
                    </div>
                `;
                container.appendChild(div);
            });

            // 如果开启语音，自动播报第一步
            if(voiceEnabled) speakText("开始导航，" + steps[0].text);
        }

        function closeNavigation() {
            document.getElementById('nav-overlay').classList.add('hidden');
            synthesis.cancel(); // 停止语音
        }

        function toggleVoiceGuide() {
            voiceEnabled = !voiceEnabled;
            const btn = document.querySelector('.nav-actions button:nth-child(1)');
            if (voiceEnabled) {
                btn.innerText = "🔊 语音播报：开";
                btn.style.background = "#27AE60";
                speakText("语音导航已开启，请跟随指引前行");
            } else {
                btn.innerText = "🔊 语音播报：关";
                btn.style.background = "#34495E";
                synthesis.cancel();
            }
        }

        function speakText(text) {
            if (!('speechSynthesis' in window)) return;
            synthesis.cancel(); // 停止上一句
            const utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = 'zh-CN';
            utterance.rate = 0.9;
            synthesis.speak(utterance);
        }

        function openSystemMap() {
            const dest = document.getElementById('nav-dest-name').innerText;
            // 构造百度/高德地图Web链接，会尝试唤起App
            // 注意：实际坐标需要后端支持，这里用搜索关键词
            const url = `https://uri.amap.com/marker?position=&name=${dest}&src=elderly-app&coordinate=wgs84&callnative=1`;
            window.open(url, '_blank');
        }

        function goHome() {
            startNavigation('家', 'home');
        }
    </script>


			
		
